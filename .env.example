# LLM Provider API Keys (REQUIRED)
# Configure at least one of these in Railway

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-xxxxx

# OpenAI (GPT-4, GPT-4o)
OPENAI_API_KEY=sk-xxxxx

# Google (Gemini)
GOOGLE_API_KEY=xxxxx

# Other supported providers via LiteLLM
# GROQ_API_KEY=xxxxx
# DEEPSEEK_API_KEY=xxxxx
# MISTRAL_API_KEY=xxxxx

# HIVE Configuration (OPTIONAL)
DEFAULT_MODEL=claude-sonnet-4-20250514
HIVE_DATA_DIR=/app/data
HIVE_CREDENTIALS_DIR=/app/.hive/credentials

# Application Settings
PYTHONUNBUFFERED=1
PORT=8000
